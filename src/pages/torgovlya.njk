---
layout: layouts/base.njk
permalink: /torgovlya/
title: "Поиск и закупка товара в Китае — ООО ТЛК БАРС"
description: "Находим завод, а не посредника: проверяем производство, контролируем качество и закупаем товар в Китае напрямую. Собственная команда в Гуанчжоу, выезды на заводы, полный цикл от поиска до отгрузки."
sitemap: true
---
{% from "partials/icon.njk" import icon %}

{#
  Страница «Торговля» (/torgovlya/) — экспертный разворот закупки в Китае.
  Порядок секций — по ТЗ (раздел 1). Тексты — из словаря (torgovlya.*), структура
  списков — из _data/torgovlya.ts. Обратный мост на /logistika/ замыкает связку.
  Форма расчёта и CTA-полоса — переиспользуемая разметка с главной/логистики.
#}

{# Переиспользуемая CTA-полоса внутри страницы (CTA-1/2/3). #}
{% macro ctaBand(textKey, btnKey) %}
<section class="bg-surface">
  <div class="container py-6 md:py-8">
    <div class="flex flex-col gap-4 rounded-2xl bg-brand px-6 py-7 text-white sm:flex-row sm:items-center sm:justify-between md:px-10 md:py-8">
      <p class="text-lg font-light leading-snug md:text-xl">{{ textKey | t(locale) }}</p>
      <a
        href="{{ site.calculateUrl | localizedUrl(locale) }}"
        class="inline-flex min-h-[44px] shrink-0 items-center justify-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white transition-colors hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand"
      >
        {{ btnKey | t(locale) }}
      </a>
    </div>
  </div>
</section>
{% endmacro %}

{% include "partials/header.njk" %}

<main class="flex-1">
  {% include "partials/breadcrumbs.njk" %}

  {# ── 1. Hero — ультрамарин, H1 + форма расчёта ─────────────────────── #}
  <section class="bg-brand text-white">
    <div class="container grid items-center gap-10 py-16 md:py-20 lg:grid-cols-2 lg:gap-16 lg:py-24">
      <div>
        <h1 class="max-w-2xl text-4xl font-light leading-tight tracking-tight md:text-5xl">
          {{ "torgovlya.hero.title" | t(locale) }}
        </h1>
        <p class="mt-6 max-w-xl text-lg font-light leading-relaxed text-white/85 md:text-xl">
          {{ "torgovlya.hero.subtitle" | t(locale) }}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            href="{{ site.calculateUrl | localizedUrl(locale) }}"
            class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white transition-colors hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand"
          >
            {{ "cta.request" | t(locale) }}
          </a>
          <a
            href="#kak-rabotaem"
            class="inline-flex min-h-[44px] items-center justify-center rounded-lg border border-white/70 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand"
          >
            {{ "torgovlya.hero.secondary" | t(locale) }}
          </a>
        </div>
      </div>

      {# Форма расчёта (заглушка — обработка в assets/ts/main.ts). #}
      <form
        data-lead-form
        novalidate
        class="rounded-2xl bg-surface p-6 text-ink shadow-xl ring-1 ring-black/5 md:p-8"
      >
        <h2 class="text-xl font-medium text-ink">{{ "torgovlya.heroForm.title" | t(locale) }}</h2>
        <p class="mt-1 text-sm text-muted">{{ "torgovlya.heroForm.note" | t(locale) }}</p>

        <div class="mt-5 space-y-4">
          <div>
            <label class="field-label" for="trade-cargo">{{ "torgovlya.heroForm.cargoLabel" | t(locale) }}</label>
            <input class="field-input min-h-[44px]" id="trade-cargo" name="cargo" type="text" data-validate="required" autocomplete="off" />
            <p class="field-error" data-error-for="cargo">{{ "torgovlya.heroForm.cargoError" | t(locale) }}</p>
          </div>
          <div>
            <label class="field-label" for="trade-contact">{{ "torgovlya.heroForm.contactLabel" | t(locale) }}</label>
            <input class="field-input min-h-[44px]" id="trade-contact" name="contact" type="text" placeholder="+7 (___) ___-__-__ · @username" data-validate="contact" autocomplete="off" />
            <p class="field-error" data-error-for="contact">{{ "torgovlya.heroForm.contactError" | t(locale) }}</p>
          </div>

          <button
            type="submit"
            class="inline-flex min-h-[44px] w-full items-center justify-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white transition-colors hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
          >
            {{ "cta.calculate" | t(locale) }}
          </button>

          <p class="hidden rounded-md bg-green-50 px-4 py-3 text-sm text-green-700" data-form-success role="status">
            {{ "torgovlya.heroForm.success" | t(locale) }}
          </p>
        </div>
      </form>
    </div>
  </section>

  {# ── 2. Реальность Alibaba — боль с акцентом «до 40%» ──────────────── #}
  <section class="bg-surface">
    <div class="container section">
      <div class="grid gap-10 lg:grid-cols-3 lg:gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.alibaba.title" | t(locale) }}</h2>
          <div class="mt-6 space-y-4 text-base leading-relaxed text-muted md:text-lg">
            <p>{{ "torgovlya.alibaba.p1" | t(locale) }}</p>
            <p>{{ "torgovlya.alibaba.p2" | t(locale) }}</p>
            <p>{{ "torgovlya.alibaba.p3" | t(locale) }}</p>
          </div>
        </div>
        <div class="flex lg:items-center">
          <div class="w-full rounded-2xl border border-slate-200 bg-surface-alt p-8 text-center shadow-sm">
            <span class="block text-5xl font-light tracking-tight text-cyan-dark md:text-6xl">{{ "torgovlya.alibaba.accentValue" | t(locale) }}</span>
            <span class="mt-3 block text-base font-medium text-ink">{{ "torgovlya.alibaba.accentLabel" | t(locale) }}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# ── 3. Что нужно для прямой работы с заводом + «у нас это есть» ───── #}
  <section class="bg-surface-alt">
    <div class="container section">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.direct.title" | t(locale) }}</h2>
        <p class="mt-3 text-base leading-relaxed text-muted md:text-lg">{{ "torgovlya.direct.subtitle" | t(locale) }}</p>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {% for point in torgovlya.directPoints %}
          <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-surface p-6 shadow-sm">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan/15">
              {{ icon(point.icon, "h-7 w-7 text-cyan") }}
            </span>
            <h3 class="mt-5 text-lg font-medium text-ink">{{ point.titleKey | t(locale) }}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{{ point.textKey | t(locale) }}</p>
          </div>
        {% endfor %}
      </div>

      <div class="mt-10 rounded-2xl bg-brand p-8 text-white md:p-10">
        <p class="max-w-3xl text-lg font-light leading-relaxed md:text-xl">{{ "torgovlya.direct.closing" | t(locale) }}</p>
      </div>
    </div>
  </section>

  {{ ctaBand("torgovlya.cta1", "cta.calculate") }}

  {# ── 4. Офис в Гуанчжоу + выезды в провинции ──────────────────────── #}
  <section class="bg-surface">
    <div class="container section">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.guangzhou.title" | t(locale) }}</h2>
          <div class="mt-6 space-y-4 text-base leading-relaxed text-muted md:text-lg">
            <p>{{ "torgovlya.guangzhou.p1" | t(locale) }}</p>
            <p>{{ "torgovlya.guangzhou.p2" | t(locale) }}</p>
          </div>

          <p class="mt-8 text-sm font-medium uppercase tracking-wide text-muted">{{ "torgovlya.guangzhou.provincesLabel" | t(locale) }}</p>
          <ul class="mt-3 flex flex-wrap gap-2">
            {% for prov in torgovlya.provinces %}
              <li class="inline-flex items-center gap-1.5 rounded-full bg-cyan/10 px-4 py-1.5 text-base font-medium text-ink">
                {{ icon("map-pin", "h-4 w-4 text-cyan") }}
                {{ prov | t(locale) }}
              </li>
            {% endfor %}
          </ul>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-surface-alt p-8 md:p-10">
          <h3 class="text-xl font-medium text-ink">{{ "torgovlya.guangzhou.benefitsTitle" | t(locale) }}</h3>
          <ul class="mt-5 space-y-4">
            {% for benefit in torgovlya.guangzhouBenefits %}
              <li class="flex items-start gap-3">
                {{ icon("badge-check", "mt-0.5 h-5 w-5 shrink-0 text-cyan") }}
                <span class="text-base leading-relaxed text-muted">{{ benefit | t(locale) }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {# ── 5. Услуги полного цикла (7 пунктов) ──────────────────────────── #}
  <section class="bg-surface-alt">
    <div class="container section">
      <h2 class="max-w-3xl text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.fullCycle.title" | t(locale) }}</h2>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {% for service in torgovlya.fullCycle %}
          <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-surface p-6 shadow-sm transition hover:border-cyan hover:shadow-md">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan/15">
              {{ icon(service.icon, "h-7 w-7 text-cyan") }}
            </span>
            <h3 class="mt-5 text-lg font-medium text-ink">{{ service.titleKey | t(locale) }}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{{ service.textKey | t(locale) }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── 6. Этапы работы (процесс закупки, 01–07) ─────────────────────── #}
  <section id="kak-rabotaem" class="scroll-mt-24 bg-surface">
    <div class="container section">
      <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.process.title" | t(locale) }}</h2>

      <ol class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {% for step in torgovlya.process %}
          <li class="flex h-full flex-col rounded-2xl border border-slate-200 bg-surface p-6 transition hover:border-cyan hover:shadow-md">
            <div class="flex items-center justify-between">
              <span class="text-4xl font-light tracking-tight text-cyan/70 md:text-5xl">{{ step.num }}</span>
              {{ icon(step.icon, "h-6 w-6 text-cyan") }}
            </div>
            <h3 class="mt-5 text-lg font-medium text-ink">{{ step.titleKey | t(locale) }}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{{ step.textKey | t(locale) }}</p>
          </li>
        {% endfor %}
      </ol>
    </div>
  </section>

  {{ ctaBand("torgovlya.cta2", "cta.calculate") }}

  {# ── 7. Ответственность за качество (тёмный акцент, образец-эталон) ── #}
  <section class="bg-brand text-white">
    <div class="container section">
      <div class="max-w-3xl">
        <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10">
          {{ icon("shield-check", "h-7 w-7 text-cyan") }}
        </span>
        <h2 class="mt-6 text-3xl font-light tracking-tight md:text-4xl">{{ "torgovlya.quality.title" | t(locale) }}</h2>
        <div class="mt-6 space-y-4 text-lg font-light leading-relaxed text-white/85">
          <p>{{ "torgovlya.quality.p1" | t(locale) }}</p>
          <p>{{ "torgovlya.quality.p2" | t(locale) }}</p>
          <p>{{ "torgovlya.quality.p3" | t(locale) }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── 8. Отдельные услуги (6 услуг, десктоп 3×2) ────────────────────── #}
  <section class="bg-surface-alt">
    <div class="container section">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.separate.title" | t(locale) }}</h2>
        <p class="mt-3 text-base leading-relaxed text-muted md:text-lg">{{ "torgovlya.separate.intro" | t(locale) }}</p>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {% for service in torgovlya.separate %}
          <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-surface p-6 shadow-sm transition hover:border-cyan hover:shadow-md">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan/15">
              {{ icon(service.icon, "h-7 w-7 text-cyan") }}
            </span>
            <h3 class="mt-5 text-lg font-medium text-ink">{{ service.titleKey | t(locale) }}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{{ service.textKey | t(locale) }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {{ ctaBand("torgovlya.cta3", "cta.request") }}

  {# ── 9. Специализация: 3 направления ──────────────────────────────── #}
  <section class="bg-surface">
    <div class="container section">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.spec.title" | t(locale) }}</h2>
        <p class="mt-3 text-base leading-relaxed text-muted md:text-lg">{{ "torgovlya.spec.subtitle" | t(locale) }}</p>
      </div>

      <div class="mt-10 space-y-6">
        {# 9.1 Напольные покрытия #}
        <article class="rounded-2xl border border-slate-200 bg-surface-alt p-8 md:p-10">
          <div class="flex items-start gap-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-cyan/15">
              {{ icon("package", "h-7 w-7 text-cyan") }}
            </span>
            <div>
              <h3 class="text-2xl font-light tracking-tight text-ink">{{ "torgovlya.spec.flooring.title" | t(locale) }}</h3>
              <p class="mt-2 text-base leading-relaxed text-muted">{{ "torgovlya.spec.flooring.lead" | t(locale) }}</p>
            </div>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-3">
            {% for pt in torgovlya.flooringPoints %}
              <div class="rounded-xl bg-surface p-5 shadow-sm">
                <h4 class="text-base font-medium text-ink">{{ pt.titleKey | t(locale) }}</h4>
                <p class="mt-2 text-sm leading-relaxed text-muted">{{ pt.textKey | t(locale) }}</p>
              </div>
            {% endfor %}
          </div>

          <a href="{{ '/tovary/napolnye-pokrytiya/' | localizedUrl(locale) }}" class="mt-6 inline-flex items-center gap-1.5 text-base font-medium text-cyan-dark transition-colors hover:text-cyan">
            {{ "torgovlya.spec.flooring.link" | t(locale) }}
          </a>
        </article>

        {# 9.2 Запчасти и двигатели для китайских грузовиков #}
        <article class="rounded-2xl border border-slate-200 bg-surface-alt p-8 md:p-10">
          <div class="flex items-start gap-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-cyan/15">
              {{ icon("truck", "h-7 w-7 text-cyan") }}
            </span>
            <div>
              <h3 class="text-2xl font-light tracking-tight text-ink">{{ "torgovlya.spec.parts.title" | t(locale) }}</h3>
              <p class="mt-2 text-base leading-relaxed text-muted">{{ "torgovlya.spec.parts.lead" | t(locale) }}</p>
            </div>
          </div>

          <p class="mt-6 text-sm font-medium uppercase tracking-wide text-muted">{{ "torgovlya.spec.parts.brandsLabel" | t(locale) }}</p>
          <ul class="mt-3 flex flex-wrap gap-2">
            {% for brand in torgovlya.partsBrands %}
              <li class="rounded-full bg-cyan/10 px-4 py-1.5 text-base font-medium text-ink">{{ brand | t(locale) }}</li>
            {% endfor %}
          </ul>

          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <div>
              <h4 class="text-base font-medium text-ink">{{ "torgovlya.spec.parts.supplyTitle" | t(locale) }}</h4>
              <ul class="mt-3 space-y-2">
                {% for item in torgovlya.partsSupply %}
                  <li class="flex items-start gap-2.5">
                    {{ icon("badge-check", "mt-0.5 h-5 w-5 shrink-0 text-cyan") }}
                    <span class="text-sm leading-relaxed text-muted">{{ item | t(locale) }}</span>
                  </li>
                {% endfor %}
              </ul>
            </div>
            <div>
              <h4 class="text-base font-medium text-ink">{{ "torgovlya.spec.parts.advantagesTitle" | t(locale) }}</h4>
              <ul class="mt-3 space-y-2">
                {% for item in torgovlya.partsAdvantages %}
                  <li class="flex items-start gap-2.5">
                    {{ icon("badge-check", "mt-0.5 h-5 w-5 shrink-0 text-cyan") }}
                    <span class="text-sm leading-relaxed text-muted">{{ item | t(locale) }}</span>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>

          <a href="{{ '/tovary/zapchasti/' | localizedUrl(locale) }}" class="mt-6 inline-flex items-center gap-1.5 text-base font-medium text-cyan-dark transition-colors hover:text-cyan">
            {{ "torgovlya.spec.parts.link" | t(locale) }}
            {{ icon("arrow-right", "h-4 w-4") }}
          </a>
        </article>

        {# 9.3 Токарные и металлообрабатывающие станки («под запрос») #}
        <article class="rounded-2xl border border-slate-200 bg-surface-alt p-8 md:p-10">
          <div class="flex items-start gap-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-cyan/15">
              {{ icon("factory", "h-7 w-7 text-cyan") }}
            </span>
            <div>
              <h3 class="text-2xl font-light tracking-tight text-ink">{{ "torgovlya.spec.machines.title" | t(locale) }}</h3>
              <p class="mt-2 text-base leading-relaxed text-muted">{{ "torgovlya.spec.machines.lead" | t(locale) }}</p>
            </div>
          </div>

          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <div>
              <h4 class="text-base font-medium text-ink">{{ "torgovlya.spec.machines.typesTitle" | t(locale) }}</h4>
              <ul class="mt-3 space-y-2">
                {% for item in torgovlya.machineTypes %}
                  <li class="flex items-start gap-2.5">
                    {{ icon("badge-check", "mt-0.5 h-5 w-5 shrink-0 text-cyan") }}
                    <span class="text-sm leading-relaxed text-muted">{{ item | t(locale) }}</span>
                  </li>
                {% endfor %}
              </ul>
            </div>
            <div>
              <h4 class="text-base font-medium text-ink">{{ "torgovlya.spec.machines.howTitle" | t(locale) }}</h4>
              <ul class="mt-3 space-y-2">
                {% for item in torgovlya.machineHow %}
                  <li class="flex items-start gap-2.5">
                    {{ icon("badge-check", "mt-0.5 h-5 w-5 shrink-0 text-cyan") }}
                    <span class="text-sm leading-relaxed text-muted">{{ item | t(locale) }}</span>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>

          <p class="mt-6 rounded-xl bg-surface px-5 py-4 text-sm italic leading-relaxed text-muted">{{ "torgovlya.spec.machines.note" | t(locale) }}</p>
        </article>
      </div>
    </div>
  </section>

  {# ── 10. Долгосрочное партнёрство ─────────────────────────────────── #}
  <section class="bg-surface-alt">
    <div class="container section">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.partnership.title" | t(locale) }}</h2>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-muted md:text-lg">
          <p>{{ "torgovlya.partnership.p1" | t(locale) }}</p>
          <p>{{ "torgovlya.partnership.p2" | t(locale) }}</p>
          <p>{{ "torgovlya.partnership.p3" | t(locale) }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── 11. Тизер «Логистика» (обратный мост) → /logistika/ ──────────── #}
  <section class="bg-brand text-white">
    <div class="container section">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10">
            {{ icon("truck", "h-7 w-7 text-cyan") }}
          </span>
          <h2 class="mt-6 text-3xl font-light leading-tight tracking-tight md:text-4xl">{{ "torgovlya.logistics.title" | t(locale) }}</h2>
          <p class="mt-4 text-lg font-light leading-relaxed text-white/85">{{ "torgovlya.logistics.text" | t(locale) }}</p>
        </div>
        <a
          href="{{ '/logistika/' | localizedUrl(locale) }}"
          class="inline-flex min-h-[44px] shrink-0 items-center justify-center gap-1.5 rounded-lg border border-white/70 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand"
        >
          {{ "torgovlya.logistics.cta" | t(locale) }}
        </a>
      </div>
    </div>
  </section>

  {# ── 12. Кейсы (плейсхолдеры) — переиспользуем компонент главной ───── #}
  {% include "components/cases.njk" %}

  {# ── 13. FAQ — аккордеон + микроразметка FAQPage ──────────────────── #}
  <section class="bg-surface-alt">
    <div class="container-narrow section">
      <h2 class="text-3xl font-light tracking-tight text-ink md:text-4xl">{{ "torgovlya.faq.title" | t(locale) }}</h2>

      <div class="mt-8 space-y-3">
        {% for item in torgovlya.faq %}
          <details class="group rounded-2xl border border-slate-200 bg-surface p-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-medium text-ink [&::-webkit-details-marker]:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2">
              <span>{{ item.questionKey | t(locale) }}</span>
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-cyan/10 text-cyan">
                {{ icon("plus", "h-5 w-5 group-open:hidden") }}
                {{ icon("minus", "hidden h-5 w-5 group-open:block") }}
              </span>
            </summary>
            <p class="mt-3 text-base leading-relaxed text-muted">{{ item.answerKey | t(locale) }}</p>
          </details>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── 14. Финальный CTA — контрастная полоса ───────────────────────── #}
  <section id="zayavka" class="scroll-mt-24 bg-brand text-white">
    <div class="container section">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-3xl font-light leading-tight tracking-tight md:text-4xl">{{ "torgovlya.ctaFinal.title" | t(locale) }}</h2>
          <p class="mt-4 text-lg font-light text-white/85">{{ "torgovlya.ctaFinal.subtitle" | t(locale) }}</p>
        </div>
        <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center lg:shrink-0">
          <a
            href="{{ site.calculateUrl | localizedUrl(locale) }}"
            class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white transition-colors hover:bg-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand"
          >
            {{ "torgovlya.ctaFinal.button" | t(locale) }}
          </a>
          <a
            href="tel:{{ site.phoneHref }}"
            class="inline-flex items-center gap-2 text-base font-medium text-white transition-colors hover:text-cyan"
            aria-label="{{ 'a11y.phoneRu' | t(locale) }}"
          >
            {{ icon("phone", "h-5 w-5 text-cyan") }}
            <span>{{ site.phone }}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {# JSON-LD FAQPage — микроразметка для поисковой выдачи. #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for item in torgovlya.faq %}
      {
        "@type": "Question",
        "name": {{ (item.questionKey | t(locale)) | dump | safe }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ (item.answerKey | t(locale)) | dump | safe }}
        }
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
  </script>
</main>

{% include "partials/footer.njk" %}
