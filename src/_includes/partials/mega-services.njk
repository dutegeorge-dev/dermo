{#
  Мега-меню «Услуги» (десктоп). Оверлей на всю ширину контейнера.
  Рендерится из data/megaMenu.ts; тексты — из словаря (t), иконки — Lucide (бирюза).
  Два крыла: Логистика (шире) | Торговля (уже), разделены вертикальной линией.
#}
{% from "partials/icon.njk" import icon %}

<div class="mega-panel" data-mega-panel>
  <div class="overflow-hidden rounded-b-2xl border-t-2 border-cyan bg-surface shadow-2xl ring-1 ring-slate-200">
    <div class="grid gap-8 p-8 lg:grid-cols-[1.7fr_minmax(0,1fr)]">

      {# ── Левое крыло: ЛОГИСТИКА ─────────────────────────────────── #}
      <div class="lg:border-r lg:border-slate-200 lg:pr-8">
        {# Кликабельные «ворота» — вход на экспертную страницу. #}
        <a
          href="{{ megaMenu.logistics.gate.url | localizedUrl(locale) }}"
          class="group/gate flex items-start justify-between gap-4 rounded-xl bg-surface-alt p-4 ring-1 ring-transparent transition hover:bg-white hover:ring-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan"
        >
          <span>
            <span class="block text-sm font-semibold uppercase tracking-wider text-ink">{{ megaMenu.logistics.gate.titleKey | t(locale) }}</span>
            <span class="mt-1 block text-sm text-muted">{{ megaMenu.logistics.gate.subtitleKey | t(locale) }}</span>
          </span>
          {{ icon("arrow-right", "h-5 w-5 shrink-0 text-cyan transition-transform group-hover/gate:translate-x-1") }}
        </a>

        {# Три подгруппы с кликабельными подзаголовками-хабами.
           Колонка 1 — «По способу»; колонка 2 — «По товару», под ним «По городу».
           Распределение по колонкам — через loop.first (рендер группы идентичен). #}
        <div class="mt-6 grid gap-x-8 gap-y-6 sm:grid-cols-2">
          <div>
            {% for group in megaMenu.logistics.groups %}{% if loop.first %}
              <div>
                <a href="{{ group.url | localizedUrl(locale) }}" class="inline-flex items-center gap-1 text-sm font-medium text-ink transition-colors hover:text-cyan focus-visible:outline-none focus-visible:text-cyan">
                  {{ group.titleKey | t(locale) }}
                  {{ icon("chevron-right", "h-4 w-4 text-cyan") }}
                </a>
                <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1">
                  {% for item in group.items %}
                    <li>
                      <a href="{{ item.url | localizedUrl(locale) }}" class="flex items-center gap-2 rounded-md py-1 text-sm text-muted transition-colors hover:text-cyan focus-visible:outline-none focus-visible:text-cyan">
                        {% if item.icon %}{{ icon(item.icon, "h-4 w-4 shrink-0 text-cyan") }}{% endif %}
                        <span>{{ item.titleKey | t(locale) }}</span>
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}{% endfor %}
          </div>
          <div class="space-y-6">
            {% for group in megaMenu.logistics.groups %}{% if not loop.first %}
              <div>
                <a href="{{ group.url | localizedUrl(locale) }}" class="inline-flex items-center gap-1 text-sm font-medium text-ink transition-colors hover:text-cyan focus-visible:outline-none focus-visible:text-cyan">
                  {{ group.titleKey | t(locale) }}
                  {{ icon("chevron-right", "h-4 w-4 text-cyan") }}
                </a>
                <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1">
                  {% for item in group.items %}
                    <li>
                      <a href="{{ item.url | localizedUrl(locale) }}" class="flex items-center gap-2 rounded-md py-1 text-sm text-muted transition-colors hover:text-cyan focus-visible:outline-none focus-visible:text-cyan">
                        {% if item.icon %}{{ icon(item.icon, "h-4 w-4 shrink-0 text-cyan") }}{% endif %}
                        <span>{{ item.titleKey | t(locale) }}</span>
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}{% endfor %}
          </div>
        </div>
      </div>

      {# ── Правое крыло: ТОРГОВЛЯ ──────────────────────────────────── #}
      <div>
        <a
          href="{{ megaMenu.trade.gate.url | localizedUrl(locale) }}"
          class="group/gate flex items-start justify-between gap-4 rounded-xl bg-surface-alt p-4 ring-1 ring-transparent transition hover:bg-white hover:ring-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan"
        >
          <span>
            <span class="block text-sm font-semibold uppercase tracking-wider text-ink">{{ megaMenu.trade.gate.titleKey | t(locale) }}</span>
            <span class="mt-1 block text-sm text-muted">{{ megaMenu.trade.gate.subtitleKey | t(locale) }}</span>
          </span>
          {{ icon("arrow-right", "h-5 w-5 shrink-0 text-cyan transition-transform group-hover/gate:translate-x-1") }}
        </a>

        <ul class="mt-6 space-y-1">
          {% for service in megaMenu.trade.services %}
            <li>
              <a
                href="{{ service.url | localizedUrl(locale) }}"
                class="flex items-center gap-3 rounded-lg p-2 text-sm text-ink transition-colors hover:bg-surface-alt hover:text-cyan focus-visible:outline-none focus-visible:bg-surface-alt"
              >
                {{ icon(service.icon, "h-5 w-5 shrink-0 text-cyan") }}
                <span>{{ service.titleKey | t(locale) }}</span>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

    </div>
  </div>
</div>
