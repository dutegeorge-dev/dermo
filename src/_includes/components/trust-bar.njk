{#
  Полоса доверия — реальные проверяемые факты с бирюзовыми иконками Lucide.
  Данные — _data/home.ts (home.trust); тексты — из словаря. Светлый фон.
  Адаптив: 2 в ряд на мобайле → 3 на планшете → 6 в ряд на десктопе (ровная сетка).
#}
{% from "partials/icon.njk" import icon %}

<section class="bg-surface-alt">
  <div class="container section">
    <ul class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-6">
      {% for fact in home.trust %}
        <li class="flex flex-col items-start">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan/15">
            {{ icon(fact.icon, "h-7 w-7 text-cyan") }}
          </span>
          {# Значение — одно слово (однострочное), поэтому подписи во всех колонках
             выравниваются естественно, без резерва высоты. #}
          <span class="mt-4 text-xl font-semibold leading-tight tracking-tight text-ink md:text-2xl">{{ fact.valueKey | t(locale) }}</span>
          <span class="mt-1 text-sm text-muted">{{ fact.labelKey | t(locale) }}</span>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
